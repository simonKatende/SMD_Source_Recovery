# Recovery-specific
backup/
smoke_test/

# Installer: keep the recovered WiX source (installer/*.wxs) + build script,
# but never commit the extracted third-party payloads, the WiX toolset, or built MSIs.
installer/payload/
installer/*.msi
installer/*.wixobj
installer/*.wixpdb
tools/

# Build outputs
**/bin/
**/obj/
**/AppPackages/
**/BundleArtifacts/

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs

# Rider / ReSharper
.idea/
_ReSharper*/
*.DotSettings.user

# Build logs (we keep these in notes/ instead of letting them litter)
*.binlog

# NuGet
packages/
*.nupkg

# OS junk
Thumbs.db
desktop.ini
.DS_Store

# Temp & autosaves
*.tmp
*~
*.swp
